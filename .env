# .env v4 – финальная версия (с поддержкой видео)
# ============================================================
# Модель и API
OLLAMA_MODEL=akdengi/saiga-llama3-8b
OLLAMA_API_URL=http://localhost:11434/api/chat
MULTIMODAL_IMAGE_MODEL=llava:7b

# Генерация ответа
TEMPERATURE=0.7
NUM_CTX=16384 # это максимум
NUM_PREDICT=16384

# Роли
ASSISTANT_ROLE=Разработчик
ROLES_FILE=roles.json
SYSTEM_PROMPT=Отвечай, как программист-разработчик, ты отлично знаешь языки программирования, ты отличный DevOps, ты отлично знаешь REST API, ты отлично знаешь Linux. Отвечай кратко, по делу, без флуда, без смайликов.

# Файлы
MAX_FILE_TEXT_LENGTH=2500
AUTO_CLEAR_ON_FILE=true

# Таймауты
TIMEOUT_TOTAL=300
TIMEOUT_SOCK_READ=150

# OCR и мультимодальность
OCR_LANGUAGE=rus+eng
ENABLE_IMAGE_DESCRIPTION=true

# ============= Аудио/видео транскрипция =============
# Для доступа из контейнера используем host.docker.internal
AUDIO_TRANSCRIBER_API_URL=http://host.docker.internal:<ВАШ ПОРТ>/api/v1/transcribe
AUDIO_TRANSCRIBER_BATCH_URL=http://host.docker.internal:<ВАШ ПОРТ>/api/v1/transcribe/batch
AUDIO_LANGUAGE=ru
AUDIO_PROCESS_AUDIO=true

# Расширения (добавлены видеоформаты)
SUPPORTED_AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.ogg,.flac,.webm,.mp4,.avi,.mov,.mkv

# Увеличен максимальный размер файла до 100 МБ (для видео)
AUDIO_MAX_FILE_SIZE_MB=100

# ============= База данных =============
# Используем имя сервиса db из compose, так как БД в контейнере
DATABASE_URL=postgresql://app_user:strong_password_here@db:5432/chainlit_db
DB_USER=app_user
DB_PASSWORD=strong_password_here
DB_NAME=chainlit_db

# ============= Безопасность =============
# Фиксированный секрет (токен) для JWT – не меняйте его, чтобы токены не сбрасывались
CHAINLIT_AUTH_SECRET=<ВАШ ТОКЕН>
